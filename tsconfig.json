{
  "extends": "@tsconfig/node-ts/tsconfig.json",
  "compilerOptions": {
    "types": ["node"],
    "rootDir": "./src",
    "outDir": "./dist",
    "paths": {
      "@src/": ["./src/"],
      "@db/": ["./src/db/"],
      "@libs/": ["./src/libs/"]
    }
  },
  "include": ["./src/*/"],
  "exclude": ["node_modules"]
}
